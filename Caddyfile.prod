# Production Caddyfile for Cloudflare Tunnel deployment.
# Cloudflare terminates TLS at the edge; Caddy speaks plain HTTP on :80
# and never tries Let's Encrypt against this private-IP host.

{
	# No auto-HTTPS — Cloudflare handles TLS at the edge.
	auto_https off

	# Email kept for completeness; not used since auto_https is off.
	email {$ACME_EMAIL:admin@example.com}

	log {
		output stdout
		format console
		level INFO
	}
}

:80 {
	# Cloudflare always sends the right Host header; we accept any.

	header {
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		X-XSS-Protection          "1; mode=block"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "camera=(), microphone=(), geolocation=()"

		# Tell browsers we're served over HTTPS even though Caddy speaks HTTP
		# (Cloudflare upgraded the request).
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

		-Server
		-X-Powered-By
	}

	log {
		output stdout
		format json
		level INFO
	}

	# API: /api/* → Spring Boot
	handle /api/* {
		reverse_proxy pji-backend:8085 {
			health_uri      /actuator/health
			health_interval 15s
			health_timeout  5s
			health_status   200

			transport http {
				dial_timeout            5s
				response_header_timeout 120s
				read_timeout            120s
			}

			# Trust Cloudflare's forwarded headers; pass through to backend.
			header_up X-Real-IP          {http.request.header.CF-Connecting-IP}
			header_up X-Forwarded-For    {http.request.header.CF-Connecting-IP}
			header_up X-Forwarded-Proto  https
			header_up X-Forwarded-Host   {host}
		}
	}

	# WebSocket: /ws/* → Backend
	handle /ws/* {
		reverse_proxy pji-backend:8085 {
			transport http {
				dial_timeout            5s
				response_header_timeout 0
			}
		}
	}

	# Frontend SPA
	# No active health check: the container's own healthcheck + depends_on already
	# enforce ordering. Active probes added a race where Caddy returns 503 right
	# after startup, before its first probe lands.
	handle {
		reverse_proxy pji-frontend:3000
	}

	encode {
		gzip
		zstd
	}
}

# SigNoz observability UI — Caddy proxies to the signoz-frontend container
# (which binds 127.0.0.1:3301 only, not reachable from the LAN IP cloudflared uses).
# Browsers see https://signoz.108pog.site (Cloudflare upgraded), Caddy receives HTTP.
http://signoz.108pog.site:80 {
	reverse_proxy signoz-frontend:3301 {
		transport http {
			dial_timeout            5s
			response_header_timeout 60s
			read_timeout            300s
		}
		header_up Host {host}
	}
}

# MinIO S3 API — public endpoint for presigned URLs from the browser
# Cloudflare terminates TLS at the edge, so Caddy speaks plain HTTP on :80.
# Browsers see https://minio.108pog.site (Cloudflare upgraded), Caddy receives HTTP.
http://minio.108pog.site:80 {
	reverse_proxy minio:9000 {
		transport http {
			dial_timeout            5s
			response_header_timeout 60s
			read_timeout            300s
		}
		# Preserve the Host header MinIO signed against — critical for AWS sig v4
		header_up Host {host}
	}
}

