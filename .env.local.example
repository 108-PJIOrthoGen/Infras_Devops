# Local development env for docker compose -f docker/docker-compose.yml --project-directory .
# Copy to Infras_Devops/.env and fill in real values.

# --- Image source ---
DOCKERHUB_REPO=local
IMAGE_TAG=dev

# --- Edge / Caddy ---
DOMAIN=localhost
ACME_EMAIL=admin@localhost

# --- Spring profile ---
SPRING_PROFILES_ACTIVE=prod
APP_CORS_ALLOWED_ORIGINS=http://localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# --- Auth ---
JWT_BASE64_SECRET=ROTATE_ME_qoAEABDke07AVLepXB4aCMtsT0wMAqR5x2VFyldsnx6e75YQkJH2UcZKTjEyoNgG71SBCXfq5N6NVZxWOfsHQ==

# --- PostgreSQL ---
POSTGRES_DB=pji_advisor
POSTGRES_USER=pji_user
POSTGRES_PASSWORD=devpass123

# --- Redis ---
REDIS_PASSWORD=devpass123

# --- RabbitMQ ---
RABBITMQ_USER=pji_user
RABBITMQ_PASSWORD=devpass123
RABBITMQ_ERLANG_COOKIE=dev-erlang-cookie
RABBITMQ_MGMT_PORT=15672

# --- MinIO ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin12345
MINIO_BUCKET=pji-documents
MINIO_CONSOLE_PORT=9001
INTEGRATION_MINIO_URL=http://minio:9000

# --- AI service shared auth (backend <-> RAG) ---
AI_SERVICE_API_KEY=local-shared-key-change-me

# --- RAG (must match real provider keys) ---
OPENROUTER_API_KEY=sk-or-REPLACE_ME
QDRANT_URL=https://your-qdrant-cluster.qdrant.io
QDRANT_API_KEY=REPLACE_ME
QDRANT_COLLECTION=rag-collection
TAVILY_API_KEY=

# --- Extract Images ---
EXTRACT_QUEUE=image_processing

# --- Mail (gmail app password example) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youraccount@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
PASSWORD_RECOVERY_MAIL_FROM=youraccount@gmail.com

# --- SigNoz ---
SIGNOZ_TAG=0.64.0
OTELCOL_TAG=0.111.16
ALERTMANAGER_TAG=0.23.7
SIGNOZ_UI_PORT=3301
